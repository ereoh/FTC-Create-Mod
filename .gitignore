# Ignore everything by default
*

# Track these
!.gitignore

# Track mods
!mods/
!mods/**

# Track core texture packs
!resourcepacks/
!resourcepacks/Andrew*
!resourcepacks/Old Copper Stuffs*

# Track core shaderpacks
!shaderpacks/
!shaderpacks/ComplementaryUnbound_*
!shaderpacks/ComplementaryUnbound_*.zip
!shaderpacks/Complementary*ColorwheelPatched
!shaderpacks/Complementary*ColorwheelPatched.zip


# Xaero settings
!config/
!config/xaero/
!config/xaero/minimap/
!config/xaero/minimap/profiles/
!config/xaero/minimap/profiles/**

# Neoforge installer
!neoforge-*.jar